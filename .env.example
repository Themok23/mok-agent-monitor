# Dashboard Authentication (set DASHBOARD_PASS to enable auth)
DASHBOARD_USER=mok
DASHBOARD_PASS=

# Hook secret (must match HOOK_SECRET in your shell profile)
HOOK_SECRET=

# Neon PostgreSQL (required for Vercel deployment)
DATABASE_URL=

# Remote dashboard URL (set in shell profile for hooks to dual-POST)
# DASHBOARD_REMOTE_URL=https://your-app.vercel.app
